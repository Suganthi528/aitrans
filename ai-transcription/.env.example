# AI Transcription Service Configuration
PORT=5002
HOST=0.0.0.0

# Whisper Model Size (tiny, base, small, medium, large)
# tiny: fastest, least accurate
# base: good balance for real-time
# small: better accuracy, slower
# medium/large: best accuracy, requires GPU
WHISPER_MODEL=base

# Translation Service (google, deepl, libre)
TRANSLATION_SERVICE=google

# DeepL API Key (optional, if using DeepL)
DEEPL_API_KEY=

# Audio Processing
AUDIO_CHUNK_DURATION=2
SAMPLE_RATE=16000

# Logging
LOG_LEVEL=INFO
